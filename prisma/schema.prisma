model ExternalSystemMapping {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  external_system_id      String    @db.Uuid
  entity_type             String    @db.VarChar(50)
  entity_id               String    @db.Uuid // no FK — polymorphic
  external_id             String    @db.VarChar(150)
  external_secondary_id   String?   @db.VarChar(150)
  external_reference_type String?   @db.VarChar(50)
  external_sku            String?   @db.VarChar(100)
  sync_status             String    @default("not_synced") @db.VarChar(20)
  sync_version            Int       @default(0)
  sync_direction          String    @default("outbound") @db.VarChar(20)
  last_synced_at          DateTime? @db.Timestamptz(6)
  last_sync_error         String?
  sync_attempts           Int       @default(0)
  is_synced               Boolean   @default(false)
  created_from            String    @default("local") @db.VarChar(20)
  updated_from            String    @default("local") @db.VarChar(20)
  manual_override         Boolean   @default(false)
  has_local_changes       Boolean   @default(false)

