  is_active       Boolean   @default(true)
  last_run_at     DateTime? @db.Timestamptz(6)
  next_run_at     DateTime? @db.Timestamptz(6)

  @@map("job_schedules")
}

/// Append-only.
model JobExecutionLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  background_job_id String    @db.Uuid
  attempt_number    Int
  started_at        DateTime  @default(now()) @db.Timestamptz(6)
  finished_at       DateTime? @db.Timestamptz(6)
  status            String    @db.VarChar(20) // success | failure
  output            Json?
  error_message     String?

  background_job BackgroundJob @relation(fields: [background_job_id], references: [id], onDelete: Cascade)

  @@index([background_job_id])
  @@map("job_execution_logs")
}

// ============================================================================
// §26 — MODULE: Centralized File Management
// ============================================================================

model File {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_name        String  @db.VarChar(255)
  storage_key      String
  storage_provider String  @db.VarChar(30) // s3 | azure_blob | local ...
  url              String?
  mime_type        String  @db.VarChar(100)
  size_bytes       BigInt
  checksum         String? @db.VarChar(128)
  uploaded_by_type String  @db.VarChar(20) // company_user | dashboard_user | system
  uploaded_by_id   String? @db.Uuid
  is_public        Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(6)

  attachments FileAttachment[]

  @@map("files")
}

model FileAttachment {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_id             String    @db.Uuid
  entity_type         String    @db.VarChar(50) // company | product | order | invoice | category | dashboard_user ...
  entity_id           String    @db.Uuid // no FK — polymorphic
  attachment_type     String    @db.VarChar(50)
  sort_order          Int       @default(0)
  caption             String?   @db.VarChar(255)
  expiry_date         DateTime? @db.Date
  verification_status String?   @db.VarChar(30) // pending | verified | rejected
  verified_by         String?   @db.Uuid
  verified_at         DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  file             File           @relation(fields: [file_id], references: [id], onDelete: Cascade)
  verified_by_user DashboardUser? @relation(fields: [verified_by], references: [id], onDelete: SetNull)

  @@index([entity_type, entity_id, attachment_type])
  @@map("file_attachments")
}

// ============================================================================
// §27 — MODULE: Global Settings & Company Settings Override Architecture
// ============================================================================

model GlobalSetting {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setting_key    String   @unique @db.VarChar(150)
  setting_value  Json
  is_overridable Boolean  @default(true)
  description    String?
  updated_by     String?  @db.Uuid
  updated_at     DateTime @updatedAt @db.Timestamptz(6)

  updated_by_user DashboardUser? @relation(fields: [updated_by], references: [id], onDelete: SetNull)

  @@map("global_settings")
}

/// Append-only.
model GlobalSettingHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  setting_key   String   @db.VarChar(150)
  setting_value Json
  changed_by    String?  @db.Uuid
  changed_at    DateTime @default(now()) @db.Timestamptz(6)

  changed_by_user DashboardUser? @relation(fields: [changed_by], references: [id], onDelete: SetNull)

  @@index([setting_key])
  @@map("global_settings_history")
}

// ============================================================================
// §28 — MODULE: Localization / Multilingual Support
// ============================================================================

model Language {
  code        String  @id @db.VarChar(10)
  name        String  @db.VarChar(100)
  native_name String  @db.VarChar(100)
  is_rtl      Boolean @default(false)
  is_active   Boolean @default(true)
  is_default  Boolean @default(false)

  companies              Company[]
  company_users          CompanyUser[]
  product_translations   ProductTranslation[]
  notification_templates NotificationTemplate[]

  @@map("languages")
}

/// Generic polymorphic translation table — default pattern for every entity
/// except `products` (which keeps its dedicated high-traffic table, §28.3).
model Translation {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type      String @db.VarChar(50) // category | catalog_menu | dashboard_page | notification_template | module | feature | menu_group ...
  entity_id        String @db.Uuid // no FK — polymorphic
  field_name       String @db.VarChar(100)
  language_code    String @db.VarChar(10)
  translated_value String

  @@unique([entity_type, entity_id, field_name, language_code])
  @@map("translations")
}

// ============================================================================
// §29.3 — MODULE: Future Company Users Module (dormant, feature-gated)
// ============================================================================

model CompanyRole {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id     String? @db.Uuid // NULL = system-provided template role
  name           String  @db.VarChar(100)
  is_system_role Boolean @default(false)

  company     Company?                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  permissions CompanyRolePermission[]
  user_roles  CompanyUserRole[]

  @@map("company_roles")
}

model CompanyPermission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique @db.VarChar(150)
  name        String  @db.VarChar(150)
  description String?

  role_permissions CompanyRolePermission[]

  @@map("company_permissions")
}

model CompanyRolePermission {
  company_role_id       String @db.Uuid
  company_permission_id String @db.Uuid
  effect                String @default("allow") @db.VarChar(10) // allow | deny

  company_role       CompanyRole       @relation(fields: [company_role_id], references: [id], onDelete: Cascade)
  company_permission CompanyPermission @relation(fields: [company_permission_id], references: [id], onDelete: Cascade)

  @@id([company_role_id, company_permission_id])
  @@map("company_role_permissions")
}

model CompanyUserRole {
  company_user_id String   @db.Uuid
  company_role_id String   @db.Uuid
  assigned_by     String?  @db.Uuid // -> dashboard_users.id (only internal staff can enable this)
  assigned_at     DateTime @default(now()) @db.Timestamptz(6)

  company_user     CompanyUser    @relation(fields: [company_user_id], references: [id], onDelete: Cascade)
  company_role     CompanyRole    @relation(fields: [company_role_id], references: [id], onDelete: Cascade)
  assigned_by_user DashboardUser? @relation(fields: [assigned_by], references: [id], onDelete: SetNull)

  @@id([company_user_id, company_role_id])
  @@map("company_user_roles")
}
