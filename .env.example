# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/cloudkitchen

# ── JWT (two audiences, four secrets) ────────────
JWT_COMPANY_ACCESS_SECRET=REPLACE_WITH_64_BYTE_RANDOM
JWT_COMPANY_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE
JWT_DASHBOARD_ACCESS_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE
JWT_DASHBOARD_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# ── CORS ─────────────────────────────────────────
CORS_ORIGINS=https://company.cloudkitchen.example,https://dashboard.cloudkitchen.example

# ── OTP ──────────────────────────────────────────
OTP_PROVIDER=mock
OTP_PEPPER=REPLACE_WITH_32_BYTE_RANDOM
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── File Storage ─────────────────────────────────
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_S3_BUCKET=
FILE_STORAGE_S3_REGION=
FILE_STORAGE_S3_ACCESS_KEY_ID=
FILE_STORAGE_S3_SECRET_ACCESS_KEY=
UPLOAD_PATH=./uploads

# ── Redis ────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Notifications ────────────────────────────────
NOTIFICATIONS_EMAIL_ENABLED=false
NOTIFICATIONS_EMAIL_PROVIDER=smtp
NOTIFICATIONS_EMAIL_FROM=noreply@cloudkitchen.example
NOTIFICATIONS_SMS_ENABLED=false
NOTIFICATIONS_PUSH_ENABLED=false

# ── Firebase Cloud Messaging (push) ──────────────
# Path to Firebase Admin SDK service account JSON (never commit this file)
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./cloud-kitchen-27de2-firebase-adminsdk-fbsvc-bafe03b145.json

# ── Error Tracking ───────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── Integrations (inert placeholders, schema-only) ──
INTEGRATIONS_DEFAULT_EXTERNAL_SYSTEM=odoo

# ── Business Defaults ────────────────────────────
BUSINESS_DEFAULT_CURRENCY=SAR
BUSINESS_DEFAULT_TIMEZONE=Asia/Riyadh
BUSINESS_DEFAULT_LANGUAGE=en
